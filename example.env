# Meshy.ai API Configuration
# Get your API key from: https://www.meshy.ai/settings/api
# Requires Pro plan ($20/month) or higher

# Production API key (uses credits)
MESHY_API_KEY=msy_your_api_key_here

# For testing without using credits, use this test key instead:
# MESHY_API_KEY=msy_dummy_api_key_for_test_mode_12345678

# MoGe-2 Modal Endpoint
# Get this URL after running: modal deploy modal/moge2_endpoint.py
MOGE2_MODAL_ENDPOINT=https://your-workspace--roomdesigner-moge2-moge2inference-process-image.modal.run

# Google Gemini API (screenshot enhancement + wall color editing)
GOOGLE_API_KEY=your_google_api_key_here
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# 3D Model Generation Backend: "meshy" or "trellis2"
# meshy = Meshy.ai API (requires MESHY_API_KEY)
# trellis2 = Self-hosted TRELLIS.2 on Modal (requires TRELLIS2_ENDPOINT)
MODEL_3D_BACKEND=meshy

# TRELLIS.2 Modal Endpoint (required if MODEL_3D_BACKEND=trellis2)
# Deploy: modal deploy modal/trellis2_endpoint.py
# Then copy the endpoint URL here
TRELLIS2_ENDPOINT=https://your-workspace--roomdesigner-trellis2-trellis2inference-generate.modal.run

# Server Base URL (for Meshy API callbacks and CORS origin)
# Set this to your server's external URL when running behind a reverse proxy
# The Meshy API needs to fetch images from your server, so this must be publicly accessible
# CORS origin is derived from this URL automatically
SERVER_BASE_URL=https://yourdomain.com/room

# Cloudflare R2 Storage (required)
# Get credentials from: Cloudflare Dashboard > R2 > Manage R2 API Tokens
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_ENDPOINT_URL=https://your_account_id.r2.cloudflarestorage.com
R2_BUCKET_NAME=room-designer
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Admin Panel Credentials
# These credentials grant access to the admin panel at /admin.html
# The admin account is separate from org accounts
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_in_production
